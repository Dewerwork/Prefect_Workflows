# Copy to .env (local) or set as GitHub Actions Secrets (CI). Never commit real values.

# --- LLM scoring (required) -------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- eBay Browse API (P0) ---------------------------------------------------
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# --- Seen-store persistence (section 10.3) ----------------------------------
# Local default is data/seen.db. For CI, point at a committed file or Turso:
# STORE_URL=libsql://your-db.turso.io
# STORE_AUTH_TOKEN=

# --- Apify (OfferUp / Facebook actors, P2) ----------------------------------
APIFY_TOKEN=

# --- Email delivery ---------------------------------------------------------
# Resend (method: resend)
RESEND_API_KEY=
# SMTP (method: smtp)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
